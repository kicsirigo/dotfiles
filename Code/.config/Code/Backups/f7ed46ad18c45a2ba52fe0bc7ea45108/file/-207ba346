@define-color mantle #1e2030;
@define-color crust #181926;

* {
    font-family: CaskaydiaCove Nerd Font;
    font-size: 15px;
}

window#waybar {
    background: transparent;
    color: #d0ff00;
}

button {
    box-shadow: inset 0 -3px transparent;
    border: none;
    border-radius: 0;
}

button:hover {
    background: inherit;
    box-shadow: inset 0 -3px @surface2;
}

#workspaces button {
    padding: 5px;
    background-color: transparent;
    color: #cad3f5;
}

/* --- Power Menu Csoport beállításai --- */

#group-power-menu {
    background-color: transparent;
    margin-left: 8px;
}

#custom-power,
#custom-lock,
#custom-reboot,
#custom-quit {
    padding: 0 12px;
    background-color: @base;
    border-radius: 10px;
    margin: 4px;
    transition: all 0.3s ease;
}

/* Színkódok a kapszulákhoz */
#custom-power { color: @blue; }
#custom-lock { color: @yellow; }
#custom-reboot { color: @green; }
#custom-quit { color: @peach; }

/* Lebegési (hover) effekt a kapszulákon */
#custom-power:hover,
#custom-lock:hover,
#custom-reboot:hover,
#custom-quit:hover {
    background-color: @surface1;
    color: @text;
}

/* --- Többi modul stílusa --- */

#network,
#clock,
#battery,
#backlight,
#pulseaudio,
#power-profiles-daemon {
    padding: 0 10px;
    background-color: @base;
    border-radius: 10px;
    margin: 4px;
}

#network { color: @sky; }
#network.disconnected { color: @red; }
#network.disabled { color: @red; }
#clock { color: @text; }
#battery { color: @green; }
#backlight { color: @text; }
#pulseaudio { color: @yellow; }
#pulseaudio.muted { color: @red; }

@keyframes blink {
    to {
        background-color: @surface2;
        color: @red;
    }
}

#battery.critical:not(.charging) {
    color: @red;
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: steps(12);
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

#power-profiles-daemon.performance { color: @red; }
#power-profiles-daemon.balanced { color: @blue; }
#power-profiles-daemon.power-saver { color: @green; }

#workspaces button.focused, 
#workspaces button.active {
    box-shadow: none;
    background-color: transparent;
}

#workspaces button:hover {
    box-shadow: none;
    background-color: transparent;
    color: @blue;
}