{
    "layer": "top",
    "position": "top",
    "modules-left": ["clock"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["battery"],
    "clock": {
        "format": "{:%H:%M}"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["яЙГ", "яЙВ", "яЙБ", "яЙА"]
    }
}