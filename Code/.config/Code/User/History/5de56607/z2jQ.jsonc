{
    "layer": "top",
    "position": "top",
    "modules-left": ["sway/mode"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["battery", "clock"],
    "clock": {
        "format": "{:%H:%M}"
    },
    "battery": {
    "interval": 60,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["", "", "", ""]
    }
}