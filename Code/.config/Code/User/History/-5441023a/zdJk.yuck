(defpoll volume :interval "1s"
  "pamixer --get-volume")

(defwindow volume-popup
  :monitor 0
  :geometry (geometry :x "10px" :y "50px" :width "200px" :height "50px" :anchor "top right")
  :stacking "fg"
  (box :orientation "v" :space-evenly false :class "vol-card"
    (label :text "Hangerő: ${volume}%")
    (scale :value volume
           :orientation "h"
           :flipped false
           :max 101
           :min 0
           :onchange "pamixer --set-volume {}")))